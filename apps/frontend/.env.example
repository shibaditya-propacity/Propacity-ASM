# ─────────────────────────────────────────────────────────────────────────────
# Propacity ASM — Frontend (Vite) environment variables
#
# USAGE:
#   cp apps/frontend/.env.example apps/frontend/.env.local
#   Vite automatically loads .env.local in development.
#
# IMPORTANT: Only variables prefixed with VITE_ are exposed to browser code.
#            Never put secrets (JWT_SECRET, DATABASE_URL, etc.) here.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ────────────────────────────────────────────────────────────────────────

# TYPE: url | REQUIRED: no | DEFAULT: http://localhost:3000/api/v1
# Base URL for all fetch() calls from the browser.
# Must NOT have a trailing slash.
# Local dev: http://localhost:3000/api/v1
# Staging:   https://api-staging.propacity-asm.com/api/v1
# Production: https://api.propacity-asm.com/api/v1 (set via Vercel env var)
VITE_API_BASE_URL=http://localhost:3000/api/v1

# ── Brand Audit integration ────────────────────────────────────────────────────

# TYPE: url | REQUIRED: no | DEFAULT: (empty — shows setup instructions)
# Base URL of the standalone Brand Audit Next.js service.
# The Brand Audit source lives at: ./Brand-audit/ (sibling of this repo).
# Start it with: cd Brand-audit && npm run dev   → runs on port 3001
# Local dev:   http://localhost:3001
# Production:  set to the deployed URL of the Brand Audit service
VITE_BRAND_AUDIT_URL=http://localhost:3001

# ── Feature flags (add as needed) ─────────────────────────────────────────────

# TYPE: boolean | REQUIRED: no | DEFAULT: false
# Set to "true" to enable React Query devtools in non-production builds.
# VITE_ENABLE_QUERY_DEVTOOLS=false

# ── Analytics (add as needed) ─────────────────────────────────────────────────

# TYPE: string | REQUIRED: no
# TODO: add analytics provider key here when analytics is set up.
# VITE_ANALYTICS_KEY=
