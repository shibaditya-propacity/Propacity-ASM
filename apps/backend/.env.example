# ─────────────────────────────────────────────────────────────────────────────
# Propacity ASM — Backend environment variables
#
# USAGE:
#   cp apps/backend/.env.example apps/backend/.env
#   Fill in your values, then: node scripts/validate-env.js
#
# Run the validate script before starting the server to catch missing vars early.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────

# TYPE: url | REQUIRED: yes
# PostgreSQL connection string used by Prisma.
# Local setup:  createdb propacity_asm  &&  then use the URL below.
# Production:   use the DATABASE_URL from Railway/Render/Supabase dashboard.
DATABASE_URL=postgresql://user:password@localhost:5432/propacity_asm

# ── Authentication ─────────────────────────────────────────────────────────────

# TYPE: secret | REQUIRED: yes | MIN LENGTH: 32 characters
# HMAC-SHA256 key for signing JWTs. Must be at least 32 characters.
# Generate a secure value: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-at-least-32-random-characters

# TYPE: string | REQUIRED: no | DEFAULT: 7d
# JWT token expiry duration. Uses ms/zeit format: 7d, 24h, 60m, etc.
JWT_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────────────────────────

# TYPE: number | REQUIRED: no | DEFAULT: 3000
PORT=3000

# TYPE: string | REQUIRED: no | DEFAULT: development
# Values: development | production | test
NODE_ENV=development

# ── Logging ────────────────────────────────────────────────────────────────────

# TYPE: string | REQUIRED: no | DEFAULT: info
# pino log level. Values: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# ── CORS ───────────────────────────────────────────────────────────────────────

# TYPE: url | REQUIRED: no | DEFAULT: allows all origins (dev only)
# In production, set to the exact frontend origin to prevent CORS abuse.
# Example: https://app.propacity-asm.com
# TODO: set this in your deployment environment before going to production.
CORS_ORIGIN=http://localhost:5173

# ── Self-reference URL ─────────────────────────────────────────────────────────

# TYPE: url | REQUIRED: in production (if not on Render)
# The public URL of this backend service, used for internal SSE callbacks.
# On Render this is auto-injected as RENDER_EXTERNAL_URL — no action needed.
# On other hosts set it explicitly: https://your-backend.onrender.com
# API_BASE_URL=https://your-backend.onrender.com

# ── BullMQ / Redis (background jobs) ──────────────────────────────────────────

# TYPE: url | REQUIRED: only if background jobs are enabled
# Redis connection URL for BullMQ job queues.
# Local: redis://localhost:6379
# TODO: uncomment and fill in when BullMQ workers are activated.
# REDIS_URL=redis://localhost:6379

# ── Brand Audit — AI providers ────────────────────────────────────────────────

# TYPE: secret | REQUIRED: yes (for brand audit module)
# Anthropic Claude API key. Used for all AI dimension analysis and vision analysis.
ANTHROPIC_API_KEY=sk-ant-...

# ── Brand Audit — Data collection APIs ───────────────────────────────────────
# All of the following are used by the brand audit data collection pipeline.
# Brand audits will partially run without them — missing sources are logged and skipped.

# TYPE: secret | REQUIRED: no | DEFAULT: (skips SERP + SEO data)
# Serper API key for Google SERP results and competitor discovery.
# Get at: https://serper.dev
SERPER_API_KEY=

# TYPE: secret | REQUIRED: no | DEFAULT: (skips Google Reviews)
# Apify API token for the Google Reviews actor (YVrEOM9F4GoyYkkUU).
# Get at: https://apify.com → Settings → Integrations → API token
APIFY_TOKEN=

# TYPE: secret | REQUIRED: no | DEFAULT: (skips Instagram data)
# Apify API key for Instagram scraper actor.
APIFY_API_KEY=

# TYPE: secret | REQUIRED: no | DEFAULT: (skips company enrichment)
# People Data Labs (PDL) API key for company enrichment.
# Get at: https://www.peopledatalabs.com
COMPANY_ENRICH_API_KEY=

# TYPE: secret | REQUIRED: no | DEFAULT: (skips Meta Ads data)
# MetAPI key for Meta Ad Library access.
METAPI_API_KEY=

# TYPE: secret | REQUIRED: no | DEFAULT: (skips Google Places details)
# Geoapify API key for place details lookup.
# Get at: https://www.geoapify.com
GEOAPIFY_API_KEY=

# TYPE: secret | REQUIRED: no | DEFAULT: (skips Google Places reviews)
# Google Places API key for place details and reviews.
GOOGLE_PLACES_API_KEY=

# TYPE: secret | REQUIRED: no | DEFAULT: (skips YouTube metrics)
# YouTube Data API v3 key for channel stats.
# Get at: https://console.cloud.google.com
YOUTUBE_DATA_API_KEY=

# TYPE: url | REQUIRED: no | DEFAULT: http://localhost:11235
# Base URL for your Crawl4AI self-hosted instance.
# Run locally: docker run -d -p 11235:11235 --shm-size=1g unclecode/crawl4ai:latest
CRAWL4AI_BASE_URL=http://localhost:11235

# ── Brand Lookup — Enhanced Enrichment ────────────────────────────────────────

# TYPE: secret | REQUIRED: no | DEFAULT: (skips BuiltWith tech stack enrichment)
# BuiltWith API key for detailed technology detection (CMS, frameworks, plugins).
# Free tier available at: https://api.builtwith.com
# Falls back to HTML pattern detection when not set.
BUILTWITH_API_KEY=

# TYPE: secret | REQUIRED: no | DEFAULT: (skips PageSpeed scores)
# Google PageSpeed Insights API key for Core Web Vitals scores.
# Get at: https://developers.google.com/speed/docs/insights/v5/get-started
# Works without key at reduced rate limit (1 req/2s).
PAGESPEED_API_KEY=

# ── SEO Module — Google OAuth ─────────────────────────────────────────────────
# Shared with the Integrations module OAuth flow for GSC and GA4.
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials

# TYPE: string | REQUIRED: yes (for SEO + Integrations OAuth)
GOOGLE_CLIENT_ID=

# TYPE: secret | REQUIRED: yes (for SEO + Integrations OAuth)
GOOGLE_CLIENT_SECRET=

# TYPE: url | REQUIRED: yes | Must match the redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/oauth/callback

# OAuth scopes (informational — these are passed during the frontend OAuth initiation)
# GSC_SCOPES=https://www.googleapis.com/auth/webmasters.readonly
# GA4_SCOPES=https://www.googleapis.com/auth/analytics.readonly
