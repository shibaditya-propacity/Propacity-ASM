# ─────────────────────────────────────────────────────────────────────────────
# Propacity ASM — Backend environment variables
#
# USAGE:
#   cp apps/backend/.env.example apps/backend/.env
#   Fill in your values, then: node scripts/validate-env.js
#
# Run the validate script before starting the server to catch missing vars early.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────

# TYPE: url | REQUIRED: yes
# PostgreSQL connection string used by Prisma.
# Local setup:  createdb propacity_asm  &&  then use the URL below.
# Production:   use the DATABASE_URL from Railway/Render/Supabase dashboard.
DATABASE_URL=postgresql://user:password@localhost:5432/propacity_asm

# ── Authentication ─────────────────────────────────────────────────────────────

# TYPE: secret | REQUIRED: yes | MIN LENGTH: 32 characters
# HMAC-SHA256 key for signing JWTs. Must be at least 32 characters.
# Generate a secure value: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-at-least-32-random-characters

# TYPE: string | REQUIRED: no | DEFAULT: 7d
# JWT token expiry duration. Uses ms/zeit format: 7d, 24h, 60m, etc.
JWT_EXPIRES_IN=7d

# ── Server ─────────────────────────────────────────────────────────────────────

# TYPE: number | REQUIRED: no | DEFAULT: 3000
PORT=3000

# TYPE: string | REQUIRED: no | DEFAULT: development
# Values: development | production | test
NODE_ENV=development

# ── Logging ────────────────────────────────────────────────────────────────────

# TYPE: string | REQUIRED: no | DEFAULT: info
# pino log level. Values: trace | debug | info | warn | error | fatal | silent
LOG_LEVEL=info

# ── CORS ───────────────────────────────────────────────────────────────────────

# TYPE: url | REQUIRED: no | DEFAULT: allows all origins (dev only)
# In production, set to the exact frontend origin to prevent CORS abuse.
# Example: https://app.propacity-asm.com
# TODO: set this in your deployment environment before going to production.
CORS_ORIGIN=http://localhost:5173

# ── BullMQ / Redis (background jobs) ──────────────────────────────────────────

# TYPE: url | REQUIRED: only if background jobs are enabled
# Redis connection URL for BullMQ job queues.
# Local: redis://localhost:6379
# TODO: uncomment and fill in when BullMQ workers are activated.
# REDIS_URL=redis://localhost:6379
