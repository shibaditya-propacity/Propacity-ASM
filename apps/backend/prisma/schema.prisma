generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// CORE — tenants, users, sessions, audit
// =============================================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  workshops          GrowthWorkshop[]
  prospects          GrowthProspect[]
  brandAudits        GrowthBrandAudit[]
  prospectActivities GrowthProspectActivity[]
  auditDevelopers    AuditDeveloper[]
  audits             Audit[]
  clients            Client[]
  integrations       Integration[]
  seoSnapshots       SeoSnapshot[]
  seoKeywords        SeoKeyword[]
  seoActions         SeoAction[]
  socialProfiles     SocialProfile[]
  socialSnapshots    SocialSnapshot[]
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email     String   @unique
  name      String
  role      String   @default("agency_member")
  passwordHash String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("users")
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  actorId      String
  action       String
  resourceType String
  resourceId   String
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, resourceType, resourceId])
  @@map("audit_logs")
}

// =============================================================
// MODULE: GROWTH
// =============================================================

model GrowthWorkshop {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  format           String   // 'Online' | 'In-person'
  city             String?
  venue            String?
  date             String   // ISO date string YYYY-MM-DD
  time             String?
  capacity         Int
  ticketPrice      Int      @default(0)
  registered       Int      @default(0)
  attended         Int      @default(0)
  adSpend          Int      @default(0)
  cpRegistration   Int      @default(0)
  speaker          String?
  registrationLink String?
  tags             String?
  notes            String?
  audienceSegment  String?
  campaignBudget   Int      @default(0)
  expectedCPR      Int      @default(0)
  status           String   @default("Upcoming") // WorkshopStatus
  createdByName    String?
  deletedAt        DateTime?
  deletedById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  prospects GrowthProspect[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@map("growth_workshops")
}

model GrowthProspect {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workshopId       String
  workshop         GrowthWorkshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  name             String
  designation      String?
  company          String
  city             String?
  scale            String?  // 'Small' | 'Mid' | 'Large'
  phone            String?
  email            String?
  source           String?
  classification   String?  // ProspectClassification
  stage            String   @default("Registered") // ProspectStage
  fitScore         Int?
  estimatedDealSize Int?
  attended         Boolean  @default(false)
  registeredAt     DateTime @default(now())
  oneOnOneAt       String?
  notes            String?
  lastActivity     DateTime @default(now())
  ownerPm          String?
  hasAudit         Boolean  @default(false)
  hasProposal      Boolean  @default(false)
  deletedAt        DateTime?
  deletedById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  activities  GrowthProspectActivity[]
  brandAudits GrowthBrandAudit[]
  fullAudits  Audit[]

  @@index([tenantId, createdAt])
  @@index([tenantId, stage])
  @@index([tenantId, workshopId])
  @@map("growth_prospects")
}

model GrowthProspectActivity {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prospectId  String
  prospect    GrowthProspect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  actorId     String
  type        String   // 'stage_change' | 'note' | 'call' | 'email' | 'meeting'
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId, prospectId, createdAt])
  @@map("growth_prospect_activities")
}

model GrowthBrandAudit {
  id                          String   @id @default(cuid())
  tenantId                    String
  tenant                      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prospectId                  String
  prospect                    GrowthProspect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  type                        String   @default("Brand Positioning") // AuditType
  status                      String   @default("Pending") // AuditStatus
  generatedAt                 DateTime?
  generatedBy                 String?
  overallScore                Int?
  dimensions                  Json     @default("[]")
  benchmarks                  Json     @default("[]")
  topThreeOpportunities       Json     @default("[]")
  estimatedAnnualUpliftLeads  Int?
  estimatedAnnualUpliftRevenue BigInt?
  competitorsAnalysed         Json     @default("[]")
  dataSources                 Json     @default("[]")
  notes                       String?
  deletedAt                   DateTime?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, prospectId])
  @@index([tenantId, status])
  @@map("growth_brand_audits")
}

// =============================================================
// MODULE: BRAND AUDIT (full AI-powered audit engine)
// =============================================================

model AuditDeveloper {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brandName         String
  legalName         String?
  domain            String?
  city              String?
  yearEstablished   Int?
  positioning       String?
  productType       String?
  microMarkets      String[]
  targetSegments    String[]
  promoterName      String?
  promoterLinkedIn  String?
  websiteUrl        String?
  instagramHandle   String?
  facebookUrl       String?
  linkedinUrl       String?
  youtubeUrl        String?
  whatsappNumber    String?
  gmbPlaceId        String?
  acres99Url        String?
  housingUrl        String?
  magicbricksUrl    String?
  reraNumbers       String[]
  reraState         String?
  adSpendRange      String?
  adPlatforms       String[]
  crmTool           String?
  competitors       String[]
  metaAdLibraryName String?
  pdlData           Json?
  collateralDocs    Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  audits Audit[]

  @@index([tenantId])
  @@index([tenantId, brandName])
  @@map("audit_developers")
}

model Audit {
  id               String          @id @default(cuid())
  tenantId         String
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  developerId      String
  developer        AuditDeveloper  @relation(fields: [developerId], references: [id], onDelete: Cascade)
  prospectId       String?
  prospect         GrowthProspect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  auditorName      String?
  auditDate        DateTime        @default(now())
  objective        String?
  knownRedFlags    String?
  overallScore     Float?
  status           String          @default("DRAFT")
  collectedData    Json?
  dataSourceStatus Json?
  dimensions       Json            @default("[]")
  assets           Json            @default("[]")
  manualOverrides  Json?
  deletedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, developerId])
  @@index([tenantId, prospectId])
  @@map("audits")
}

// =============================================================
// MODULE: INTEGRATIONS
// =============================================================

// Client = the developer brand managed by the agency.
// One tenant (agency) has many clients.
model Client {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  industry  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  integrations   Integration[]
  seoSnapshots   SeoSnapshot[]
  seoKeywords    SeoKeyword[]
  seoActions     SeoAction[]
  socialProfiles SocialProfile[]

  @@index([tenantId, createdAt])
  @@map("int_clients")
}

// Global lookup table — no tenantId (acceptable for seed data).
model Provider {
  id              String   @id @default(cuid())
  name            String   @unique
  category        String   // 'AdPlatforms'|'Analytics'|'SeoTools'|'ReviewsListings'|'SocialMedia'|'Communication'|'FinanceBilling'|'CrmLeadRouting'|'DomainsHosting'|'AiContent'
  description     String
  authType        String   // 'OAUTH2' | 'API_KEY'
  logoUrl         String
  moduleRelevance String[] // 'Ads'|'Social'|'SEO'|'Website'|'Reputation'|'Promoter'|'Launch'
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  integrations        Integration[]
  platformIntegration PlatformIntegration?

  @@index([category])
  @@map("int_providers")
}

// Per-client integration. One client can have at most one integration per provider.
model Integration {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  providerId   String
  provider     Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  status       String   @default("NOT_CONNECTED") // 'CONNECTED'|'NOT_CONNECTED'|'EXPIRED'|'ERROR'
  accountLabel String?
  credentials  Json     @default("{}")
  lastSyncAt   DateTime?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  syncLogs SyncLog[]

  @@unique([clientId, providerId])
  @@index([tenantId, createdAt])
  @@index([clientId, createdAt])
  @@index([clientId, status])
  @@index([providerId])
  @@map("int_integrations")
}

model SyncLog {
  id            String      @id @default(cuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  triggeredAt   DateTime    @default(now())
  status        String      // 'SUCCESS' | 'FAILED' | 'IN_PROGRESS'
  recordsSynced Int?
  errorMessage  String?

  @@index([integrationId, triggeredAt])
  @@map("int_sync_logs")
}

model PlatformIntegration {
  id           String   @id @default(cuid())
  providerId   String   @unique
  provider     Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  status       String   @default("NOT_CONNECTED") // 'CONNECTED'|'NOT_CONNECTED'|'EXPIRED'|'ERROR'
  accountLabel String?
  credentials  Json     @default("{}")
  lastSyncAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("int_platform_integrations")
}

// =============================================================
// MODULE: SEO
// =============================================================

// Per-client SEO data snapshot captured on each sync run.
model SeoSnapshot {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  syncDate        DateTime @default(now())
  clicks          Int      @default(0)
  impressions     Int      @default(0)
  ctr             Float    @default(0)
  avgPosition     Float    @default(0)
  indexedPages    Int      @default(0)
  crawlErrors     Int      @default(0)
  mobileIssues    Int      @default(0)
  topPages        Json     @default("[]")
  topQueries      Json     @default("[]")
  organicSessions Json     @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, clientId, syncDate])
  @@index([tenantId, clientId])
  @@map("seo_snapshots")
}

// Keywords being actively tracked for a client.
model SeoKeyword {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  keyword       String
  currentRank   Int?
  previousRank  Int?
  searchVolume  Int?
  weeklyHistory Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, clientId, keyword])
  @@index([tenantId, clientId, createdAt])
  @@map("seo_keywords")
}

// Recommended actions generated from each sync run.
model SeoAction {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    String    @default("TECHNICAL") // 'CONTENT' | 'TECHNICAL' | 'SCHEMA' | 'BACKLINKS'
  impactLevel String    @default("MEDIUM")    // 'HIGH' | 'MEDIUM' | 'LOW'
  effortLevel String    @default("MEDIUM")    // 'QUICK' | 'MEDIUM' | 'HEAVY'
  status      String    @default("PENDING")   // 'PENDING' | 'IN_PROGRESS' | 'COMPLETED'
  assignedTo  String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId, clientId, status])
  @@index([tenantId, clientId, createdAt])
  @@map("seo_actions")
}

// =============================================================
// MODULE: SOCIAL MEDIA
// =============================================================

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  YOUTUBE
}

// Per-client social media handle + connection state, one row per platform.
model SocialProfile {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId    String
  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform    SocialPlatform
  handle      String         // username / page slug / channel ID
  profileUrl  String?
  autoFetched Boolean        @default(false) // true if handle was discovered automatically
  isConnected Boolean        @default(false)
  accessToken String?        // encrypted; null when we use server-side API key
  tokenExpiry DateTime?
  lastSyncAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  snapshots SocialSnapshot[]

  @@unique([clientId, platform])
  @@index([tenantId, clientId])
  @@index([tenantId, platform])
  @@map("social_profiles")
}

// Point-in-time metrics snapshot for a single platform.
model SocialSnapshot {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  socialProfileId String
  socialProfile   SocialProfile @relation(fields: [socialProfileId], references: [id], onDelete: Cascade)
  snapshotDate    DateTime      @default(now())
  followers       Int           @default(0)
  following       Int?
  posts           Int?
  avgLikes        Float?
  avgComments     Float?
  avgShares       Float?
  engagementRate  Float?
  reach           Int?
  impressions     Int?
  profileViews    Int?
  topPosts        Json          @default("[]") // [{ url, likes, comments, shares, date }]
  audienceDemog   Json?         // { age: [], gender: [], location: [] }
  createdAt       DateTime      @default(now())

  @@index([socialProfileId, snapshotDate])
  @@index([tenantId, snapshotDate])
  @@map("social_snapshots")
}
