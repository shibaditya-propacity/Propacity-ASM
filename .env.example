# ─────────────────────────────────────────────────────────────────────────────
# Propacity ASM — Root environment variable reference
#
# USAGE:
#   cp .env.example .env        # never commit .env — it is in .gitignore
#   Edit .env with your values and run: node scripts/validate-env.js
#
# Each variable is documented with:
#   TYPE      — string | url | number | boolean | secret
#   REQUIRED  — whether the app refuses to start without it
#   DEFAULT   — safe default for local dev (absent = no default, must be set)
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ──────────────────────────────────────────────────────────────────

# TYPE: url | REQUIRED: yes
# Full PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local dev: postgresql://localhost:5432/propacity_asm (no user/password if using peer auth)
DATABASE_URL=postgresql://user:password@localhost:5432/propacity_asm

# TYPE: secret | REQUIRED: yes | MIN LENGTH: 32 characters
# HS256 JWT signing secret. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# NEVER use the example value in production.
JWT_SECRET=replace-me-with-at-least-32-random-characters

# TYPE: number | REQUIRED: no | DEFAULT: 3000
# Port the Express server listens on.
PORT=3000

# TYPE: string | REQUIRED: no | DEFAULT: development
# Controls log level and error verbosity. Values: development | production | test
NODE_ENV=development

# ── Frontend (Vite — must be prefixed with VITE_) ─────────────────────────────

# TYPE: url | REQUIRED: no | DEFAULT: http://localhost:3000/api/v1
# Base URL for all API calls from the browser. Must NOT have a trailing slash.
VITE_API_BASE_URL=http://localhost:3000/api/v1
